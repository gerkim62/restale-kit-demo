# Backend Environment Variables

# The port the backend server should listen on.
# Default: 3000
PORT=3000

# PostgreSQL database connection string.
# Example for a local database: postgresql://postgres:postgres@localhost:5432/todo_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/todo_db

# Secret key used for signing JSON Web Tokens (JWT).
# Change this to a secure random string in production.
JWT_SECRET=your_jwt_secret_key_here

# Application environment. 
# Set to 'production' in production to enforce secure cookies (https).
# Default: development
NODE_ENV=development

# Allowed client origins for CORS.
# For multiple domains, separate them with a comma: http://localhost:5173,https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Redis connection URL for distributed Pub/Sub (optional, omit for local in-memory fallback)
# Example: redis://localhost:6379 or rediss://your-remote-redis-domain:6379
REDIS_URL=



